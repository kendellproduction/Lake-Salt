rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requester an authenticated admin?
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // leads — public write (website form), admin read/update/delete
    match /leads/{id} {
      allow create: if true;           // website contact form
      allow read, update, delete: if isAdmin();
    }

    // All other collections — admin only
    match /admins/{id}     { allow read, write: if isAdmin(); }
    match /projects/{id}   { allow read, write: if isAdmin(); }
    match /tasks/{id}      { allow read, write: if isAdmin(); }
    match /bartenders/{id} { allow read, write: if isAdmin(); }
    match /payments/{id}   { allow read, write: if isAdmin(); }
    match /events/{id}     { allow read, write: if isAdmin(); }
    match /expenses/{id}   { allow read, write: if isAdmin(); }
    match /inventory/{id}  { allow read, write: if isAdmin(); }
  }
}
