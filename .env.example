# EmailJS Configuration
# Get these values from https://dashboard.emailjs.com/

# Public Key from EmailJS
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE

# Service ID (set up your email service in EmailJS dashboard)
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID_HERE

# Template ID (create your email template in EmailJS dashboard)
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID_HERE

# Python API Server (for daily recipe endpoint)
# Leave empty to use fallback recipe
VITE_API_URL=http://localhost:5000
